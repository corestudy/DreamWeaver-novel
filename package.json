{
  "name": "dreamweaver-novel",
  "version": "1.0.0",
  "description": "Production release of DreamWeaver-novel",
  "author": "DreamWeaver-novel",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "desktop": "electron .",
    "build:desktop": "electron-builder --win nsis",
    "clean:user-data": "node scripts/clean-user-data.js",
    "clean:dist": "node scripts/clean-dist.js",
    "lightweight": "npm.cmd run clean:user-data && npm.cmd run clean:dist",
    "check": "node --check server.js && node --check db.js && node --check ai.js && node --check electron/main.js && node --check public/shelf.js && node --check public/book-config.js && node --check public/workspace.js && node --check public/outline.js && node --check public/cheat-mode.js && npm.cmd run check:api-doc",
    "check:api-doc": "node scripts/check-api-doc-sync.js",
    "postinstall": "npm.cmd run native:rebuild:node",
    "native:rebuild:node": "npm rebuild better-sqlite3 --update-binary",
    "native:check": "node scripts/check-native-sqlite.js",
    "native:rebuild:electron": "electron-builder install-app-deps",
    "build:desktop:ready": "npm.cmd run check && npm.cmd run native:check && npm.cmd run native:rebuild:electron && npm.cmd run build:desktop -- --config.win.signAndEditExecutable=false && npm.cmd run native:rebuild:node && npm.cmd run native:check"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "better-sqlite3": "11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.novel.assistant",
    "productName": "DreamWeaver-novel",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "server.js",
      "db.js",
      "ai.js",
      "package.json",
      "scripts/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
